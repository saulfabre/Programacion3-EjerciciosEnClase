<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ConversorMonedasController"
            spacing="15"
            alignment="CENTER">
    
            <Label fx:id="lblTitulo"
                   text="Conversor de Monedas"/>
            
            <Label fx:id="lblMonto"
                   Text="Monto en pesos dominicanos"/>

            <TextField fx:id="tfMonto"
                       promptText="0.00"/>
            
            <Label fx:id="lblMonedaDestino"
                       text="Moneda destino"/>
            
            <ComboBox fx:id="cbMonedas"
                          promptText="Seleccione una moneda">

                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="USD"/>
                            <String fx:value="EUR"/>
                        </FXCollections>
                    </items>

                </ComboBox>

    <HBox spacing="15" alignment="CENTER">

            <Button fx:id="btnConvertir"
                    text="Convertir"
                    onAction="#convertirMoneda"/>
            
            <Button fx:id="btnLimpiar"
                    text="Limpiar"/>
    </HBox>
            <Label fx:id="lblResultado"
                   text="Resultado:"/>

            <Label fx:id="lblEstado"
                   text="Esperando información..."/>
</VBox>
            


