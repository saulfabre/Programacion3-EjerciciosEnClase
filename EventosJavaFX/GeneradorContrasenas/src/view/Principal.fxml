<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<BorderPane prefWidth="664.0" styleClass="contenedor-principal" stylesheets="@../styles/estilos.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.PrincipalController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
   <center>
      <VBox prefWidth="602.0" styleClass="contenedor-principal-formulario" BorderPane.alignment="CENTER">
         <children>
            <HBox styleClass="contenedor-titulo-principal">
               <children>
                  <Label fx:id="lblTitulo" alignment="CENTER" prefHeight="100.0" prefWidth="605.0" styleClass="titulo-principal" text="Generador de Contraseñas" />
               </children>
            </HBox>
            <VBox spacing="18.0" styleClass="contenedor-formulario" stylesheets="@../styles/estilos.css">
               <children>
                  <Label fx:id="lblLongitud" styleClass="label-formulario" text="Longitud" />
                  <TextField fx:id="tfLongitud" minHeight="-Infinity" onKeyPressed="#generarEnter" prefHeight="35.0" promptText="999" />
                  <CheckBox fx:id="cbMayusculas" mnemonicParsing="false" styleClass="checkbox-formulario" text="Incluir mayúsculas" />
                  <CheckBox fx:id="cbNumeros" mnemonicParsing="false" styleClass="checkbox-formulario" text="Incluir números" />
                  <CheckBox fx:id="cbSimbolos" mnemonicParsing="false" styleClass="checkbox-formulario" text="Incluir símbolos" />
                  <VBox>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                     <children>
                        <HBox spacing="16.0" styleClass="contenedor-botones" stylesheets="@../styles/estilos.css">
                           <children>
                              <Button fx:id="btnGenerar" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#generar" onMouseEntered="#mouseEntrando" onMouseExited="#mouseSaliendo" prefHeight="35.0" prefWidth="150.0" styleClass="btn-generar" text="Generar">
                                 <HBox.margin>
                                    <Insets />
                                 </HBox.margin>
                              </Button>
                              <Button fx:id="btnLimpiar" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#limpiar" prefHeight="35.0" prefWidth="150.0" styleClass="btn-limpiar" text="Limpiar" />
                           </children>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding>
                        </HBox>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </VBox>
            <VBox spacing="18.0" styleClass="contenedor-resultado">
               <children>
                  <Label fx:id="lblContrasenaGenerada" styleClass="label-contrasena-generada" text="Contraseña generada:" />
                  <HBox styleClass="contenedor-final">
                     <children>
                        <Label fx:id="lblResultado" styleClass="label-resultado" text="Esperando configuración...">
                           <HBox.margin>
                              <Insets left="15.0" />
                           </HBox.margin>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="20.0" right="20.0" top="20.0" />
                     </padding>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </VBox>
         </children>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
      </VBox>
   </center>
</BorderPane>
